{
  "name": "dont-waste",
  "version": "0.1.0",
  "description": "Local-first token reduction orchestrator for coding agents",
  "type": "module",
  "bin": {
    "dont-waste": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx --no-cache src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@dont-waste/adapters": "workspace:*",
    "@dont-waste/catalog": "workspace:*",
    "@dont-waste/core": "workspace:*",
    "@dont-waste/dashboard-api": "workspace:*",
    "@dont-waste/telemetry": "workspace:*",
    "commander": "^13.1.0",
    "execa": "^9.5.2"
  },
  "devDependencies": {
    "tsup": "^8.4.0"
  }
}
